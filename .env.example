# Copy to .env (compose reads it automatically). All values have safe defaults in
# docker-compose.yml; this file documents them and lets each member override locally.

# --- Ollama / models -------------------------------------------------------
OLLAMA_URL=http://ollama:11434
# Main multimodal model (vision/OCR). NOTE: the plan said "gemma4:12b" which does
# not exist on Ollama; the real family is gemma3. On an 8 GB GPU, 12b may OOM once
# a page image is added during OCR — switch to the fallback below if so.
MODEL_TAG=gemma3:12b
# Lighter multimodal fallback for weak GPUs (<= 8 GB VRAM). Also multimodal.
MODEL_TAG_FALLBACK=gemma3:4b
# Embeddings (used from Phase 3 onward).
EMBED_MODEL_TAG=bge-m3

# --- Agentic layer ---------------------------------------------------------
TOOLS_ENABLED=1
MAX_TOOL_STEPS=5
TOOL_BUDGET_PER_DOC=20

# --- Paths (inside the container) ------------------------------------------
DB_PATH=/data/db/evrak.duckdb
STORAGE_PATH=/data/storage
RULES_PATH=/data/rules

# --- API -------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8756
